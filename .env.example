# Facebook Graph API Configuration
# These are now optional as they can be loaded from the database via Settings
FB_GRAPH_VERSION=v24.0

# Facebook OAuth Configuration (Required for Settings > Connect)
FB_APP_ID=your_app_id_here
FB_APP_SECRET=your_app_secret_here

# Webhook Configuration
FB_WEBHOOK_VERIFY_TOKEN=your_secure_verify_token_here

# Security
ENCRYPTION_KEY=32_char_random_string_for_token_encryption
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars

# App
APP_URL=https://your-app-domain.example

# Calendly Integration (OAuth)
# Required:
# - APP_URL (above): used for OAuth callback URL /api/auth/calendly/callback
# - CALENDLY_OAUTH_CLIENT_ID
# - CALENDLY_OAUTH_CLIENT_SECRET
# - CALENDLY_TRACKING_SECRET (min 32 chars): signs tracking tokens in booking links
CALENDLY_OAUTH_CLIENT_ID=your_calendly_oauth_client_id_here
CALENDLY_OAUTH_CLIENT_SECRET=your_calendly_oauth_client_secret_here
CALENDLY_TRACKING_SECRET=replace_with_a_long_random_secret_min_32_chars
CALENDLY_OAUTH_SCOPES=users:read webhooks:write scheduled_events:read

# Advanced (optional): only set if you need non-default Calendly endpoints
# Default API base: https://api.calendly.com
# Default OAuth base: https://auth.calendly.com
CALENDLY_API_BASE_URL=https://api.calendly.com
CALENDLY_OAUTH_BASE_URL=https://auth.calendly.com

# OTP Abuse Controls
OTP_SEND_LIMIT_WINDOW_SECONDS=600
OTP_SEND_MAX_ATTEMPTS=3
OTP_SEND_BLOCK_SECONDS=900
OTP_VERIFY_LIMIT_WINDOW_SECONDS=600
OTP_VERIFY_MAX_ATTEMPTS=10
OTP_VERIFY_BLOCK_SECONDS=900

# Supabase (Required)
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Resend Email Configuration
RESEND_API_KEY=your_resend_api_key_here

# NVIDIA AI Configuration (Setter AI)
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=qwen/qwen3.5-397b-a17b
NVIDIA_TEMPERATURE=0.3
NVIDIA_MAX_TOKENS=16000
